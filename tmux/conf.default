# Reset all binding
# (.tmux.reset.conf generated via command "tmux -f /dev/null -L temp start-server \; list-keys > .tmux.reset.conf" )
#source-file ~/.tmux.reset.conf

# remap prefix to C-a
#unbind C-b
#set -g prefix M-a
set-option -g prefix 'C-\' 
#bind 'C-\' send-prefix # sending prefix to application is lost by below window-management option

# Core settings
set -sg escape-time 0 # voorkomt Escape-vertraging in vim
set-window-option -g mode-keys vi # determins how to navigate in copy-mode Prefix + [
bind r source-file ~/.tmux.conf \; display "Config Reloaded!" # Reload tmux.conf
# - (additional) for claude settings
set -g focus-events on
set -g allow-passthrough on
set -s extended-keys on
set -as terminal-features 'xterm*:extkeys'
set -g set-clipboard on

# Window management
bind-key 'C-\' last-window
set -g base-index 1 # start numbering with 1
set-option -g allow-rename off # prevent apps from renaming the window title
set-window-option -g alternate-screen on # tmux scrollback (Ctrl-\ [) vervangt het voordeel van off
set -g renumber-windows on

# Pane management 
# - creation
bind | split-window -h
bind - split-window -v
unbind '"'
unbind %
# - indexing
setw -g pane-base-index 1 # start numbering with 1
set-option -g allow-set-title off # prevent apps from renaming the pane title
# - moving around panes, with ALT and vi-keys (without leader)
bind-key -n M-h select-pane -L
bind-key -n M-j select-pane -D
bind-key -n M-k select-pane -U
bind-key -n M-l select-pane -R
# - resize panes met H, J, K, L (stappen van 5)
bind -r Left  resize-pane -L 5
bind -r Down  resize-pane -D 5
bind -r Up    resize-pane -U 5
bind -r Right resize-pane -R 5

# Toggle mouse support (tmux 2.1 and above)
set -g mouse off
# - Mouse ON
bind M set-option -g mouse on # \; display-message "Mouse ON"
# - Mouse off  - to avoid conflicts with terminal-client, or applications like vim, less, etc.
bind m set-option -g mouse off # \; display-message "Mouse OFF"

# Enable prompt colors
set -g default-terminal "xterm-256color" # should be aligned with 'Report terminal type' of terminal-emulator; this current value fixes weird terminal behaviour like not working of ctrl-K otherwise
set -ag terminal-overrides ",xterm-256color:RGB"
#set -g default-terminal "tmux-256color" # preferred option for newer tmux versions

# Disable closing shell with ctrl-d (@once)
set-environment -g 'IGNOREEOF' 2

# Statusbalk
# - Algemene styling
#set -g status-style bg=default,fg=white   # Transparante achtergrond (pakt je terminal kleur)
#set -g status-style bg=colour235,fg=white
#set -g status-style bg=#1c1c1c,fg=white
#set -g status-style bg='#262626',fg='#ffffff
set -g status-style bg='#3b4252',fg='#eceff4'
set -g status-position top	# or 'bottom'
set -g status-interval 5    # refresh every 5 seconds

# - Linkerkant: Sessie naam
set -g status-left-length 30
set -g status-left "#[fg=green] #S #[default] "

# - Midden: Vensterlijst (de "tabs")
set -g window-status-format "#[fg=brightblack]#I:#W"
set -g window-status-current-format "#[fg=cyan]#I:#W*"
set -g window-status-separator "  "

# - Rechterkant: Datum en Tijd
set -g status-right-length 50
#set -g status-right "#[fg=yellow]%d-%m #[fg=white]| #[fg=cyan]%H:%M "
set -g status-right "#[fg=cyan]Mouse: #{?mouse,#[fg=green]AAN,#[fg=red]UIT}#[default] | #[fg=cyan]%H:%M "

set -g pane-border-status bottom
set -g pane-border-format " [ Pane: #P ] "
